# EIA Open Data API key — register free at https://www.eia.gov/opendata/
EIA_API_KEY=your_api_key_here

# Database
DATABASE_URL=sqlite:///data/energy_forecasting.db

# MLflow tracking server (local by default)
MLFLOW_TRACKING_URI=./mlruns

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Default region to process when --region not specified
DEFAULT_REGION=MISO

# Data date range defaults
DEFAULT_START_DATE=2022-01-01
DEFAULT_END_DATE=2023-12-31
